<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detailed Notes</title>
    <link rel="icon" type="image/svg+xml" href="../images/favicon.svg">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">Go back</a>
        <form action="/edit" method="post">
            <input class="block w-1/4 rounded-md outline-none px-5 py-2 bg-zinc-800" type="text" placeholder="Previous name" name="previous" readonly value="<%= filename  %>">
            <input class="block w-1/4 rounded-md outline-none mt-2 px-5 py-2 resize-none bg-zinc-800" placeholder="New name" name="new" value="<%= filename  %>">
            <span class="text-zinc-400">.txt</span>
            <textarea class="block w-2/4 rounded-md outline-none mt-2 px-5 py-2 resize-none bg-zinc-800" placeholder="Update your task" rows="5" name="details"><%= details %></textarea>
            <input class="mt-2 bg-yellow-600 px-5 py-2" type="submit" value="Update Task">
        </form>
    </div>
</body>
</html>